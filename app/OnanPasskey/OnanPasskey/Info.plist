<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required Bluetooth usage descriptions -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Onan Passkey uses Bluetooth to broadcast your key to the lock controller.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>Onan Passkey advertises as a BLE peripheral so the lock can find your device.</string>

    <!-- Background Bluetooth modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-peripheral</string>
        <string>bluetooth-central</string>
    </array>

    <!-- Custom URL scheme for QR enrollment -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>onanpasskey</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.onan.passkey.enroll</string>
        </dict>
    </array>

    <key>CFBundleName</key>
    <string>Onan Passkey</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
</dict>
</plist>
